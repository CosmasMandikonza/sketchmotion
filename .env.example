# Default provider flag for the new structured storyboard-planning path.
# Existing Google/Gemini UI features remain on their current code path until explicitly rewired.
VITE_AI_PROVIDER=google

# Google Gemini API Key for current client-side AI features.
# Current legacy Google path uses:
# - gemini-2.5-flash-image for sketch polish/editing
# - gemini-2.5-flash for text analysis, prompting, and director outputs
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Client-side media routing.
# These keep local prompt building + Replicate working by default while leaving
# Gemini/Google available as optional providers when configured.
# VITE_VIDEO_PROMPT_PROVIDER=local
# VITE_VIDEO_PROMPT_PROVIDER_FALLBACK=gemini
# VITE_POLISH_PROVIDER_PRIMARY=replicate
# VITE_POLISH_PROVIDER_FALLBACK=google

# Supabase Configuration
# Get these values from your Supabase project dashboard at https://supabase.com/dashboard

# Your Supabase project URL (e.g., https://xxxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=your_supabase_url_here

# Your Supabase anon/public key (safe to use in client-side code)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Edge Function secrets for the new Z.AI / GLM storyboard planning path.
# Set these as Supabase secrets on the server, not in client-side .env files.
# Default judged path:
# - glm-5.1 on the Z.AI coding endpoint handles storyboard analysis, planning,
#   continuity synthesis, render strategy, and revision reasoning in one path.
# STORYBOARD_AI_PROVIDER=zai
# ZAI_API_KEY=your_zai_api_key_here
# ZAI_CODING_API_BASE_URL=https://api.z.ai/api/coding/paas/v4
# ZAI_GLM_PLANNING_MODEL=glm-5.1
# Optional legacy / experimental compatibility only:
# ZAI_GENERAL_API_BASE_URL=https://api.z.ai/api/paas/v4
# ZAI_GLM_VISION_MODEL=GLM-5V-Turbo
# ZAI_API_BASE_URL=https://api.z.ai/api/paas/v4
# ZAI_GLM_STORYBOARD_MODEL=glm-4.6v
# ZAI_THINKING_TYPE=enabled

# Supabase Edge Function secrets for Replicate-based media paths.
# Set these as Supabase secrets on the server, not in client-side .env files.
# REPLICATE_API_TOKEN=your_replicate_api_token_here
# REPLICATE_POLISH_MODEL=black-forest-labs/flux-kontext-pro
# REPLICATE_VIDEO_MODEL=bytedance/seedance-2.0-fast
# VIDEO_PROVIDER_PRIMARY=replicate
# VIDEO_PROVIDER_FALLBACK=google
# Optional future compatibility:
# GOOGLE_VIDEO_MODEL=veo-3-fast
